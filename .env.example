# SPEC-1 Environment Configuration
# Copy to .env and fill in values

# Storage
SPEC1_STORE_PATH=spec1_intelligence.jsonl
SPEC1_DB_PATH=spec1.db
SPEC1_ENVIRONMENT=production
SPEC1_LOG_LEVEL=INFO

# Anthropic API (Tier 1 LLM — investigation verification + briefing)
ANTHROPIC_API_KEY=sk-ant-...

# LLM Fallback Configuration
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_TIER_PRIORITY=claude,ollama,mock

# Dev mode: skip Tier 1 (Claude) entirely, route straight to Ollama (saves tokens)
# SPEC1_DEV_MODE=true

# Tier 2: Ollama (local, free)
OLLAMA_MODEL=llama3
OLLAMA_HOST=localhost:11434
OLLAMA_AUTO_SPAWN=true
SPEC1_OLLAMA_URL=http://localhost:11434

# Tier 3 is always available (rule-based, no config needed)

# LLM session log (append-only JSONL)
SPEC1_LLM_LOG_PATH=logs/llm_fallback.jsonl

# Override Claude model used by fallback client (default: claude-haiku-4-5-20251001)
# SPEC1_LLM_CLAUDE_MODEL=claude-haiku-4-5-20251001

# API Server
SPEC1_API_HOST=0.0.0.0
SPEC1_API_PORT=8000

# API Key Authentication (Phase 3 — SaaS)
# When set, all non-public endpoints require X-API-Key header or ?api_key= query param
# Leave unset (or empty) for open access (self-hosted / local mode)
# SPEC1_API_KEY=

# Webhook Delivery (Phase 3 — integrations)
# Comma-separated HTTPS URLs to POST cycle.completed events to
# SPEC1_WEBHOOK_URLS=https://hooks.slack.com/...,https://your-integration.example.com/webhook
# Optional HMAC-SHA256 signing secret (adds X-Spec1-Signature header)
# SPEC1_WEBHOOK_SECRET=
# Webhook HTTP timeout in seconds (default: 10)
# SPEC1_WEBHOOK_TIMEOUT=10

# CORS origins (production — comma-separated; defaults to open in dev mode)
# SPEC1_CORS_ORIGINS=https://app.spec1.ai,https://spec1.ai

# Scheduler (cron expression for daily cycle, default: 06:00 LA time)
SPEC1_CRON_HOUR=6
SPEC1_CRON_MINUTE=0
SPEC1_TIMEZONE=America/Los_Angeles

# Feed timeouts
SPEC1_FEED_TIMEOUT=15
